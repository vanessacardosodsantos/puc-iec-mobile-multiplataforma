# Copia esse arquivo pra .env (sem .example) e preenche.
# .env está no .gitignore — NUNCA comite tokens reais.
#
# Gerar em: https://www.themoviedb.org/settings/api
#
# Aceita 2 formatos (o starter detecta automático):
#   - API Key v3 (32 chars hex): EXPO_PUBLIC_TMDB_TOKEN=828ce092ac...
#   - API Read Access Token v4 (JWT longo): EXPO_PUBLIC_TMDB_TOKEN=eyJhbGc...

EXPO_PUBLIC_TMDB_TOKEN=<sssssssssssssssssssssss>